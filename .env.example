PORT=3000
HOST=0.0.0.0

# BigCommerce API account credentials
BIGCOMMERCE_STORE_HASH=your_store_hash
BIGCOMMERCE_ACCESS_TOKEN=your_bigcommerce_access_token

# HubSpot private app access token
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# Optional: configure this same header when creating the BigCommerce webhook.
WEBHOOK_SECRET=change_me
WEBHOOK_SECRET_HEADER=x-webhook-secret

# Optional: requires custom HubSpot properties named bigcommerce_customer_id and bigcommerce_company_id.
HUBSPOT_INCLUDE_BIGCOMMERCE_ID=false
